{
    "openapi": "3.1.0",
    "info": {
        "title": "Executive APP",
        "version": "0.1.0"
    },
    "servers": [
        {
            "url": "/executive"
        }
    ],
    "paths": {
        "/entebus/account/token": {
            "get": {
                "tags": [
                    "Token"
                ],
                "summary": "Fetch Token",
                "operationId": "fetch_token_entebus_account_token_get",
                "responses": {
                    "200": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {}
                            }
                        }
                    }
                }
            },
            "post": {
                "tags": [
                    "Token"
                ],
                "summary": "Create Token",
                "description": "**Issue a new access token for an executive after validating credentials.**\n\n- Verify the `username` and `password`.\n- Ensure the executive account is in `active status` before allowing token creation.\n- Maintain a limit on the number of active tokens based on `MAX_EXECUTIVE_TOKENS` to control token rotation.\n- **Token Creation**\n    - Generate a new `Executive Token` with a pair of access and refresh tokens.\n    - The `expires_in` indicates the number of seconds until the access token expires (based on MAX_ACCESS_TOKEN_VALIDITY).\n    - The `refresh_before` indicates the datetime when the refresh token expires (based on MAX_REFRESH_TOKEN_VALIDITY).\n    - A new access token can be generated by using the refresh token before it expires.",
                "operationId": "create_token_entebus_account_token_post",
                "requestBody": {
                    "content": {
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "$ref": "#/components/schemas/Body_create_token_entebus_account_token_post"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "201": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ExecutiveTokenSchema"
                                }
                            }
                        }
                    },
                    "412": {
                        "description": "Precondition Failed",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                },
                                "examples": {
                                    "InactiveAccount": {
                                        "summary": "{'X-Error': 'InactiveAccount'}",
                                        "value": {
                                            "detail": "The account is not in active status"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                },
                                "examples": {
                                    "InvalidCredentials": {
                                        "summary": "{'X-Error': 'InvalidCredentials'}",
                                        "value": {
                                            "detail": "Invalid username or password"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            },
            "delete": {
                "tags": [
                    "Token"
                ],
                "summary": "Delete Token",
                "description": "Revoke an executive token.\n\n- Verify the provided access token exists in the database.\n- Invalidate the current access token.",
                "operationId": "delete_token_entebus_account_token_delete",
                "requestBody": {
                    "content": {
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "$ref": "#/components/schemas/Body_delete_token_entebus_account_token_delete"
                            }
                        }
                    }
                },
                "responses": {
                    "204": {
                        "description": "Successful Response"
                    },
                    "401": {
                        "description": "Unauthorized",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                },
                                "examples": {
                                    "InvalidToken": {
                                        "summary": "{'X-Error': 'InvalidToken'}",
                                        "value": {
                                            "detail": "Invalid token"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                },
                                "examples": {
                                    "UnknownValue": {
                                        "summary": "{'X-Error': 'UnknownValue'}",
                                        "value": {
                                            "detail": "Unknown access_token is provided"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "403": {
                        "description": "Forbidden",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                },
                                "examples": {
                                    "NoPermission": {
                                        "summary": "{'X-Error': 'NoPermission'}",
                                        "value": {
                                            "detail": "This user has no permission to perform this action"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                },
                "security": [
                    {
                        "Executive HTTP Bearer": []
                    }
                ]
            }
        },
        "/entebus/account/token/refresh": {
            "post": {
                "tags": [
                    "Token"
                ],
                "summary": "Refresh Token",
                "description": "**Refresh an executive's access token using a valid refresh token.**\n\n- Verify the provided refresh token exists in the database.\n- Invalidate the current refresh token.\n- **Token Creation**\n    - Generate a new `Executive Token` with a pair of access and refresh tokens.\n    - The `expires_in` indicates the number of seconds until the access token expires (based on MAX_ACCESS_TOKEN_VALIDITY).\n    - The `refresh_before` indicates the datetime when the refresh token expires (based on MAX_REFRESH_TOKEN_VALIDITY).\n    - A new access token can be generated by using the refresh token before it expires.",
                "operationId": "refresh_token_entebus_account_token_refresh_post",
                "requestBody": {
                    "content": {
                        "application/x-www-form-urlencoded": {
                            "schema": {
                                "$ref": "#/components/schemas/Body_refresh_token_entebus_account_token_refresh_post"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "201": {
                        "description": "Successful Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ExecutiveTokenSchema"
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Unauthorized",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                },
                                "examples": {
                                    "InvalidToken": {
                                        "summary": "{'X-Error': 'InvalidToken'}",
                                        "value": {
                                            "detail": "Invalid token"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ErrorResponse"
                                },
                                "examples": {
                                    "UnknownValue": {
                                        "summary": "{'X-Error': 'UnknownValue'}",
                                        "value": {
                                            "detail": "Unknown refresh_token is provided"
                                        }
                                    }
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation Error",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HTTPValidationError"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "Body_create_token_entebus_account_token_post": {
                "properties": {
                    "username": {
                        "type": "string",
                        "maxLength": 32,
                        "title": "Username"
                    },
                    "password": {
                        "type": "string",
                        "maxLength": 32,
                        "title": "Password"
                    },
                    "platform_type": {
                        "$ref": "#/components/schemas/PlatformType",
                        "description": "OTHER: 1, WEB: 2, NATIVE: 3, SERVER: 4",
                        "default": 1
                    },
                    "client_details": {
                        "anyOf": [
                            {
                                "type": "string",
                                "maxLength": 1024
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Client Details"
                    },
                    "grant_type": {
                        "$ref": "#/components/schemas/GrantType",
                        "description": "PASSWORD: password, REFRESH_TOKEN: refresh_token",
                        "default": "password"
                    }
                },
                "type": "object",
                "required": [
                    "username",
                    "password"
                ],
                "title": "Body_create_token_entebus_account_token_post"
            },
            "Body_delete_token_entebus_account_token_delete": {
                "properties": {
                    "id": {
                        "anyOf": [
                            {
                                "type": "integer"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Id"
                    }
                },
                "type": "object",
                "title": "Body_delete_token_entebus_account_token_delete"
            },
            "Body_refresh_token_entebus_account_token_refresh_post": {
                "properties": {
                    "refresh_token": {
                        "type": "string",
                        "title": "Refresh Token"
                    },
                    "grant_type": {
                        "$ref": "#/components/schemas/GrantType",
                        "description": "PASSWORD: password, REFRESH_TOKEN: refresh_token",
                        "default": "refresh_token"
                    }
                },
                "type": "object",
                "required": [
                    "refresh_token"
                ],
                "title": "Body_refresh_token_entebus_account_token_refresh_post"
            },
            "ErrorResponse": {
                "properties": {
                    "detail": {
                        "type": "string",
                        "title": "Detail"
                    }
                },
                "type": "object",
                "required": [
                    "detail"
                ],
                "title": "ErrorResponse",
                "description": "Standardized error response schema.\n\nAttributes:\n    detail (str): Human-readable error message describing the problem."
            },
            "ExecutiveTokenSchema": {
                "properties": {
                    "id": {
                        "type": "integer",
                        "title": "Id"
                    },
                    "executive_id": {
                        "type": "integer",
                        "title": "Executive Id"
                    },
                    "expires_in": {
                        "type": "integer",
                        "title": "Expires In"
                    },
                    "refresh_before": {
                        "type": "string",
                        "format": "date-time",
                        "title": "Refresh Before"
                    },
                    "platform_type": {
                        "type": "integer",
                        "title": "Platform Type"
                    },
                    "client_details": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Client Details"
                    },
                    "updated_on": {
                        "anyOf": [
                            {
                                "type": "string",
                                "format": "date-time"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Updated On"
                    },
                    "created_on": {
                        "type": "string",
                        "format": "date-time",
                        "title": "Created On"
                    },
                    "access_token": {
                        "type": "string",
                        "title": "Access Token"
                    },
                    "refresh_token": {
                        "type": "string",
                        "title": "Refresh Token"
                    },
                    "token_type": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Token Type",
                        "default": "bearer"
                    }
                },
                "type": "object",
                "required": [
                    "id",
                    "executive_id",
                    "expires_in",
                    "refresh_before",
                    "platform_type",
                    "client_details",
                    "updated_on",
                    "created_on",
                    "access_token",
                    "refresh_token"
                ],
                "title": "ExecutiveTokenSchema",
                "description": "Schema for executive token response including the tokens."
            },
            "GrantType": {
                "type": "string",
                "enum": [
                    "password",
                    "refresh_token"
                ],
                "title": "GrantType",
                "description": "Authentication grant types."
            },
            "HTTPValidationError": {
                "properties": {
                    "detail": {
                        "items": {
                            "$ref": "#/components/schemas/ValidationError"
                        },
                        "type": "array",
                        "title": "Detail"
                    }
                },
                "type": "object",
                "title": "HTTPValidationError"
            },
            "PlatformType": {
                "type": "integer",
                "enum": [
                    1,
                    2,
                    3,
                    4
                ],
                "title": "PlatformType",
                "description": "Platform used to access the system."
            },
            "ValidationError": {
                "properties": {
                    "loc": {
                        "items": {
                            "anyOf": [
                                {
                                    "type": "string"
                                },
                                {
                                    "type": "integer"
                                }
                            ]
                        },
                        "type": "array",
                        "title": "Location"
                    },
                    "msg": {
                        "type": "string",
                        "title": "Message"
                    },
                    "type": {
                        "type": "string",
                        "title": "Error Type"
                    }
                },
                "type": "object",
                "required": [
                    "loc",
                    "msg",
                    "type"
                ],
                "title": "ValidationError"
            }
        },
        "securitySchemes": {
            "Executive HTTP Bearer": {
                "type": "http",
                "scheme": "bearer"
            }
        }
    }
}