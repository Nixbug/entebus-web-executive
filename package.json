{
	"name": "entebus-web-executive",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"prebuild": "node ./scripts/prebuild-generate-api.mjs",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"generate:api": "openapi-generator-cli generate -i https://dev-api.entebus.com/executive/openapi.json -g typescript-fetch -o ./src/lib/api --skip-validate-spec"
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.0",
		"@eslint/js": "^9.36.0",
		"@sveltejs/adapter-auto": "^6.1.0",
		"@sveltejs/kit": "^2.43.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.0",
		"@types/node": "^22",
		"@vite-pwa/sveltekit": "^1.0.1",
		"eslint": "^9.36.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.12.4",
		"globals": "^16.4.0",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"svelte": "^5.39.5",
		"svelte-check": "^4.3.2",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.44.1",
		"vite": "^7.1.7",
		"vite-plugin-pwa": "^1.1.0"
	},
	"dependencies": {
		"@openapitools/openapi-generator-cli": "^2.30.2",
		"@codemirror/autocomplete": "^6.20.0",
		"@codemirror/commands": "^6.10.1",
		"@codemirror/lang-javascript": "^6.2.4",
		"@codemirror/search": "^6.6.0",
		"@codemirror/state": "^6.5.4",
		"@codemirror/theme-one-dark": "^6.1.3",
		"@codemirror/view": "^6.39.11",
		"@types/codemirror": "^5.60.17",
		"bootstrap": "^5.3.8",
		"codemirror": "^6.0.2",
		"ol": "^10.7.0",
		"svelte-sonner": "^1.0.8",
		"zod": "^4.1.12"
	}
}